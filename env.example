# Обязательное
BOT_TOKEN=123456:ABCDEF_your_token_here

# Канал для проверки подписки
# Можно указать @username или числовой id (например -1001234567890)
CHANNEL_ID_OR_USERNAME=@my_channel
CHANNEL_URL=https://t.me/my_channel

# Медиа приветствия
WELCOME_MEDIA_TYPE=photo
WELCOME_MEDIA_FILE_ID_OR_URL=AgACAgQAAxkBAA... # или https://...

# Уроки (видео)
LESSON1_VIDEO_FILE_ID_OR_URL=BAACAgQAAxkBAA... # или https://...
LESSON2_VIDEO_FILE_ID_OR_URL=BAACAgQAAxkBAA...
LESSON3_VIDEO_FILE_ID_OR_URL=BAACAgQAAxkBAA...

# (Опционально) Путь к SQLite
SQLITE_PATH=./data/bot.sqlite

# Админы бота (для команды /reset_all), через запятую
# Узнать свой id можно, включив DEBUG_FILE_ID=1 и отправив любое фото/видео — либо добавить отдельный /myid.
ADMIN_IDS=568790144

# (Опционально) Разрешить админские команды только из конкретного чата
# Например, ваш личный диалог с ботом: ADMIN_CHAT_ID=568790144
ADMIN_CHAT_ID=

# Витрина (кнопки после финального текста). Если не указать URL — кнопка покажет подсказку.
COMMUNITY_URL=https://t.me/your_private_community
TRAINING_URL=https://t.me/your_manager_or_bot
PERSONAL_TRAINING_URL=https://t.me/your_manager_or_bot
MENTORING_URL=https://t.me/your_manager_or_bot

# Реквизиты оплаты (для ручной модерации чеков)
TRC20_WALLET=TEgk91aY8Q3V93sNhMrCeujDjrqdqbnJZv
BANK_CARD_NUMBER=2204310714904359

# Чаты, куда выдаём одноразовые инвайты после подтверждения оплаты
# Бот должен быть админом в этих чатах и иметь право создавать invite links.
COMMUNITY_CHAT_ID=-1001234567890
COURSES_CHAT_ID=-1001234567890
